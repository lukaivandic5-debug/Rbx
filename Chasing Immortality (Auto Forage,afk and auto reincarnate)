local isRunning = false

local function startFarmLoop()
    if isRunning then 
        isRunning = false
        startButton.Text = "REINCARNATE: OFF"
        startButton.BackgroundColor3 = Color3.fromRGB(0, 170, 127)
        return 
    end
    
    isRunning = true
    startButton.BackgroundColor3 = Color3.fromRGB(255, 85, 85)
    
    local target = tonumber(targetBox.Text) or 10
    local lastUpdate = 0

    while isRunning do
        local currentTotal = getCurrentTotal()
        
        if currentTotal >= target then
            print("✅ SUCCESS! Total reached: " .. currentTotal)
            break
        end
        
        if tick() - lastUpdate > 1 then
            startButton.Text = "Farming... ("..currentTotal.."/"..target..")"
            lastUpdate = tick()
        end
        
        clickGameReincarnateButton()
        
        local args = { "Reincarnate", false }
        ReincarnateRemote:FireServer(unpack(args))
        
        task.wait(2)
    end
    
    isRunning = false
    startButton.Text = "REINCARNATE: OFF"
    startButton.BackgroundColor3 = Color3.fromRGB(0, 170, 127)
end

startButton.MouseButton1Click:Connect(startFarmLoop)
