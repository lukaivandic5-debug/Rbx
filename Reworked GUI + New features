MainTab:CreateToggle({
    Name = "Auto Reincarnate",
    CurrentValue = false,
    Flag = "AutoReincarnateToggle",
    Callback = function(Value)
        States.AutoReincarnate = Value
        if Value then
            task.spawn(function()
                while States.AutoReincarnate do
                    local currentTotal = getCurrentTotal()
                    if currentTotal >= ReincarnateTarget then
                        Rayfield:Notify({Title = "Success", Content = "Target reached: "..currentTotal, Image = 4483362458})
                        break
                    end
                    
                    clickGameReincarnateButton()
                    Remote:FireServer("Reincarnate", false)
                    task.wait(2)
                end
            end)
        end
    end,
})

MainTab:CreateToggle({
   Name = "Auto Forage",
   CurrentValue = false,
   Flag = "AutoForageToggle",
   Callback = function(Value)
      States.AutoForage = Value
      if Value then
          task.spawn(function()
              while States.AutoForage do
                  local items = {}
                  for _, obj in ipairs(Workspace:GetDescendants()) do
                      if collectSet[obj.Name] and getTargetPart(obj) then
                          table.insert(items, obj)
                      end
                  end

                  table.sort(items, function(a, b)
                      return getDistance(a) < getDistance(b)
                  end)

                  if #items > 0 then
                      collectItem(items[1])
                      task.wait(DELAY_BETWEEN_COLLECTS)
                  else
                      task.wait(1.5)
                  end
              end
          end)
      end
   end,
})

