MainTab:CreateSection("Farming & Reincarnation")

local ReincarnateTarget = 10
local TELEPORT_HEIGHT = 4
local DELAY_BETWEEN_COLLECTS = 1.9

local collectibles = {
    "Azure Serpent Grass", "Basic Herb", "Bitter Jade Grass", "Black Iron Root",
    "Blue Wave Coral Herb", "Cloud Mist Herb", "Common Spirit Grass",
    "Crimson Flame Mushroom", "Dandelion of Qi", "Healing Sunflower",
    "Heavenly Spirit Vine", "Ironbone Grass", "Moonlight Jade Leaf",
    "Mountain Green Herb", "Nine Suns Flame Grass", "Purple Lightning Orchid",
    "Red Ginseng", "Seven Star Flower", "Silverleaf Herb", "Spirit Spring Herb",
    "Starlight Dew Herb", "Thousand Year Lotus", "Wild Bitter Grass", "Wild Spirit Grass",
    "Chest"
}

local collectSet = {}
for _, name in collectibles do collectSet[name] = true end

local function getTargetPart(item)
    return item:IsA("BasePart") and item or item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
end

local function getDistance(obj)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not obj then return math.huge end
    local part = getTargetPart(obj)
    return part and (root.Position - part.Position).Magnitude or math.huge
end

local function collectItem(item)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local targetPart = getTargetPart(item)
    local prompt = item:FindFirstChild("ProximityPrompt", true)

    if targetPart and prompt then
        local oldCFrame = root.CFrame
        root.CFrame = targetPart.CFrame * CFrame.new(0, TELEPORT_HEIGHT, 0)
        task.wait(0.2) 

        prompt:InputHoldBegin()
        task.wait(prompt.HoldDuration + 0.1)
        prompt:InputHoldEnd()

        task.wait(0.1)
        root.CFrame = oldCFrame
    end
end

local function getCurrentTotal()
    local success, result = pcall(function()
        local screenGui = PlayerGui:FindFirstChild("ScreenGui", true)
        if not screenGui then return nil end
        local follower = screenGui:FindFirstChild("Follower", true)
        if not follower then return nil end
        local stats = follower:FindFirstChild("PlayerStats", true)
        if not stats then return nil end
        local totalLabel = stats:FindFirstChild("Total", true)
        if totalLabel and totalLabel:IsA("TextLabel") then
            return totalLabel.Text
        end
        return nil
    end)

    if success and result then
        local number = string.match(result, "[%d%.]+")
        if number then return tonumber(number) end
    end
    return 0
end

local function clickGameReincarnateButton()
    local screen = PlayerGui:FindFirstChild("ScreenGui")
    if not screen then return false end
    local cutscenes = screen:FindFirstChild("Cutscenes")
    if not cutscenes then return false end
    local death = cutscenes:FindFirstChild("Death")
    if not death then return false end
    local void = death:FindFirstChild("Void")
    if not void then return false end
    local btn = void:FindFirstChild("Reincarnate")
    if btn then
        firesignal(btn.MouseButton1Click)
        return true
    end
    return false
end

MainTab:CreateInput({
    Name = "Reincarnate Target",
    CurrentValue = "10",
    PlaceholderText = "Target Total",
    Flag = "ReincarnateTargetInput",
